{
  "name": "easner",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "website",
    "web",
    "mobile"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:website": "npm run dev --workspace=website",
    "dev:web": "npm run dev --workspace=web",
    "dev:mobile": "npm run start --workspace=easner-mobile",
    "build": "npm run build --workspaces --if-present",
    "build:website": "npm run build --workspace=website",
    "build:web": "npm run build --workspace=web",
    "build:shared": "npm run build --workspace=@easner/shared",
    "lint": "npm run lint --workspaces --if-present",
    "start:website": "npm run start --workspace=website",
    "start:web": "npm run start --workspace=web"
  }
}
