# App (app.easner.com) environment variables

# App URL - for emails, Bridge redirects, etc.
NEXT_PUBLIC_APP_URL=https://app.easner.com

# Site URL - Supabase auth redirectTo (forgot password)
NEXT_PUBLIC_SITE_URL=https://app.easner.com

# Office app URL - for CORS on /api/admin/* (bk.easner.com)
NEXT_PUBLIC_OFFICE_URL=https://bk.easner.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@easner.com
SENDGRID_FROM_NAME=Easner
SENDGRID_REPLY_TO=support@easner.com

# Bridge
BRIDGE_API_KEY=

# JWT (password reset)
JWT_SECRET=
